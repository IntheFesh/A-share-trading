# 运行期数据落盘(永不入库:体积大且可由数据源重建)
# 注意:用 data_store/* 而非 data_store/,否则无法再 include .gitkeep(父目录被整体排除)。
data_store/*
!data_store/.gitkeep
data_store_fin/        # 季频财务独立落盘(批 2;频率不同,与行情物理隔离)
data_store_industry/   # 行业分类独立落盘(批 4)
*.parquet

# 报告产物(落盘静态图 / Markdown 报告;按需保留,默认不入库)
trading_system/reports/output/
*.png
*.html

# IDE
.idea/
.vscode/

# 日志
*.log
logs/
